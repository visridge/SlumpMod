exec function FOV(float F) {
	if((F >= 60.0 && F <= 165.0) || PlayerReplicationInfo.bOnlySpectator) {
		DefaultFOV = F;
		DesiredFOV = DefaultFOV;

		if((F >= 60.0 && F <= 165.0) && PlayerCamera != None) {
			PlayerCamera.SetFOV( F );
			return;
		}

		if (IsLocalPlayerController()) {
			MyFOV = F;
			default.MyFOV = F;
			StaticSaveConfig();
		}
	}
}

