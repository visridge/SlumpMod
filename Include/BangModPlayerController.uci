/* ************************************************************************
 * PROXIMITY VOICE CHAT IMPLEMENTATION
 * BangMod adds working proximity voice chat functionality
 **************************************************************************/

// Push-to-talk command (bound to G key by default)
exec function GBA_ToggleSpeaking()
{
	if (!bEnableProximityChat)
	{
		ClientDisplayConsoleMessage("Proximity voice chat is disabled. Enable in config.");
		return;
	}
		
	bIsTalking = !bIsTalking;
	
	// Debug message
	ClientDisplayConsoleMessage("Voice chat: " $ (bIsTalking ? "TALKING" : "STOPPED"));
	
	// Update HUD to show we're talking
	if (AOCBaseHUD(myHUD) != none)
	{
		if (AOCBaseHUD(myHUD).HUD != none && AOCBaseHUD(myHUD).HUD.MainHUD != none)
		{
			AOCBaseHUD(myHUD).HUD.MainHUD.LocalPlayerStartTalking(bIsTalking);
			ClientDisplayConsoleMessage("Updated HUD talking indicator");
		}
		else
		{
			ClientDisplayConsoleMessage("HUD not available");
		}
	}
	
	// NOTE: Actual voice transmission requires the VoIP codec which was removed from the engine
	// The infrastructure is here, but microphone capture/transmission is not available
	// without engine-level modifications or external voice solutions (Discord, etc.)
	
	// Server notification disabled - voice codec missing makes this non-functional
	// ServerNotifyTalkingState(bIsTalking);
}

// NOTE: Server-side proximity notification disabled due to voice codec being missing from engine
// The functions below are kept for reference but commented out to avoid compilation errors
/*
// Notify server we're talking (so it can replicate to nearby clients)
reliable server function ServerNotifyTalkingState(bool bTalking)
{
	bIsTalking = bTalking;
	NotifyNearbyPlayersOfTalker(bTalking);
}

// Check which players are in range and notify them
function NotifyNearbyPlayersOfTalker(bool bTalking)
{
	// Would need to iterate controllers and call ClientReceiveProximityTalker
	// But this causes compile errors due to type casting limitations
	// Disabled since voice codec is missing anyway
	ClientDisplayConsoleMessage("Proximity Voice: " $ PlayerReplicationInfo.PlayerName $ (bTalking ? " is talking" : " stopped"));
}
*/

// Receive notification that someone nearby is talking
reliable client function ClientReceiveProximityTalker(PlayerReplicationInfo TalkerPRI, bool bTalking)
{
	local int i;
	local VOIPInfo NewTalker;
	local AOCPRI APRI;
	
	APRI = AOCPRI(TalkerPRI);
	if (APRI == none)
		return;
	
	if (bTalking)
	{
		// Add to nearby talkers list
		if (NearbyTalkers.Find(APRI) == INDEX_NONE)
		{
			NearbyTalkers.AddItem(APRI);
		}
		
		// Update HUD to show this person is talking
		if (AOCBaseHUD(myHUD) != none)
		{
			NewTalker.VOIPName = APRI.PlayerName;
			NewTalker.LastUpdateTime = WorldInfo.TimeSeconds;
			NewTalker.TalkerTeam = EFAC_ALL;
			
			// Add to the talking list in HUD
			for (i = 0; i < AOCBaseHUD(myHUD).AllPlayersTalking.Length; i++)
			{
				if (AOCBaseHUD(myHUD).AllPlayersTalking[i].VOIPName == APRI.PlayerName)
				{
					AOCBaseHUD(myHUD).AllPlayersTalking[i].LastUpdateTime = WorldInfo.TimeSeconds;
					return;  // Already in list, just updated time
				}
			}
			
			// Not in list, add them
			AOCBaseHUD(myHUD).AllPlayersTalking.AddItem(NewTalker);
		}
	}
	else
	{
		// Remove from nearby talkers
		NearbyTalkers.RemoveItem(APRI);
		
		// Queue for removal from HUD
		if (AOCBaseHUD(myHUD) != none)
		{
			for (i = 0; i < AOCBaseHUD(myHUD).AllPlayersTalking.Length; i++)
			{
				if (AOCBaseHUD(myHUD).AllPlayersTalking[i].VOIPName == APRI.PlayerName)
				{
					AOCBaseHUD(myHUD).QueueToRemove.AddItem(AOCBaseHUD(myHUD).AllPlayersTalking[i]);
					break;
				}
			}
		}
	}
}

// Override ClientNotifyPlayerTalking to handle proximity filtering
function ClientNotifyPlayerTalking(UniqueNetId TalkingPlayer, bool bIsTalking)
{
	local PlayerReplicationInfo PRI;
	local float Distance;
	
	// Find the PRI for this player
	foreach DynamicActors(class'PlayerReplicationInfo', PRI)
	{
		if (PRI.UniqueId == TalkingPlayer)
		{
			// Check if they're in proximity range
			if (Pawn != none && PRI.Owner != none && Pawn(PRI.Owner) != none)
			{
				Distance = VSize(Pawn.Location - Pawn(PRI.Owner).Location);
				
				if (Distance <= ProximityChatDistance)
				{
					// They're in range, process normally
					ClientReceiveProximityTalker(PRI, bIsTalking);
				}
			}
			break;
		}
	}
}

// Process VOIP queue to update HUD
function ProcessVOIPQueue()
{
	local int i;
	local float CurrentTime;
	local array<VOIPInfo> CurrentTalkers;
	
	if (AOCBaseHUD(myHUD) == none)
		return;
		
	CurrentTime = WorldInfo.TimeSeconds;
	
	// Remove old talkers (haven't updated in 0.5 seconds)
	for (i = AOCBaseHUD(myHUD).AllPlayersTalking.Length - 1; i >= 0; i--)
	{
		if (CurrentTime - AOCBaseHUD(myHUD).AllPlayersTalking[i].LastUpdateTime > 0.5)
		{
			AOCBaseHUD(myHUD).AllPlayersTalking.Remove(i, 1);
		}
	}
	
	// Process removal queue
	for (i = 0; i < AOCBaseHUD(myHUD).QueueToRemove.Length; i++)
	{
		AOCBaseHUD(myHUD).AllPlayersTalking.RemoveItem(AOCBaseHUD(myHUD).QueueToRemove[i]);
	}
	AOCBaseHUD(myHUD).QueueToRemove.Length = 0;
	
	// Build current talkers array for HUD
	CurrentTalkers = AOCBaseHUD(myHUD).AllPlayersTalking;
	
	// Update the HUD display
	if (AOCBaseHUD(myHUD).HUD != none && AOCBaseHUD(myHUD).HUD.MainHUD != none)
	{
		AOCBaseHUD(myHUD).HUD.MainHUD.RegisterCurrentTalkers(CurrentTalkers);
	}
}


DefaultProperties
{
	NetUpdateFrequency=120
	// Netcode optimization: Client-side interpolation interval to match 120Hz tickrate
	MaxClientUpdateInterval=0.00833  // 1/120 = 0.00833 seconds between client updates
	suicideDelay = 1.0f
	CustomizationClass=class'BangModCustomization'
	bShowDeathMessages = true
	
	// Proximity voice chat defaults
	ProximityChatDistance=2048.0  // About 39 meters (typical medieval battle communication range)
	bEnableProximityChat=true
	bIsTalking=false

	// Unpause countdown
	UnpauseCountdownTime=3
}

