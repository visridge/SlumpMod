// Ensure BangMod uses its customization class everywhere
simulated event PostBeginPlay()
{
	super.PostBeginPlay();
	if (CustomizationClass != class'BangModCustomization')
	{
		CustomizationClass = class'BangModCustomization';
	}
	
	// FPS uncapping removed - use 'UncapFPS' console command manually if desired
}

// Exec command for players to manually uncap FPS
exec function UncapFPS()
{
	local string Cmd;
	local GameEngine GEngine;
	local LocalPlayer LP;
	
	// Try obfuscated version
	// Cmd = "Set" @ "Engine.GameEngine" @ "MaxSmoothedFrameRate" @ "0";
	// ConsoleCommand(Cmd);
	// ConsoleCommand("Set Engine.GameEngine MinSmoothedFrameRate 0");
	// ConsoleCommand("Set Engine.GameEngine bSmoothFrameRate False");
	// ClientDisplayConsoleMessage("FPS uncap attempted (check with 'stat fps')");

	// Method 1: Try to access GameEngine directly through the class hierarchy
	GEngine = GameEngine(class'Engine'.static.GetEngine());
	if (GEngine != None)
	{
		GEngine.MaxSmoothedFrameRate = 165.0;
		bFPSUncapped = true;
		ClientDisplayConsoleMessage("FPS uncap to 165 enabled (check with 'stat fps')");
	}
	else
	{
		// Method 2: Try through LocalPlayer
		LP = LocalPlayer(Player);
		if (LP != None && LP.ViewportClient != None && LP.ViewportClient.Outer != None)
		{
			GEngine = GameEngine(LP.ViewportClient.Outer);
			if (GEngine != None)
			{
				GEngine.MaxSmoothedFrameRate = 165.0;
				bFPSUncapped = true;
				ClientDisplayConsoleMessage("FPS uncap to 165 enabled (check with 'stat fps')");
			}
		}
	}
	
}

// Override ProcessViewRotation to remove turn cap during parry counters
function ProcessViewRotation( float DeltaTime, out Rotator out_ViewRotation, Rotator DeltaRot )
{
	local float MaxTurnSpeed;
	local float MaxVertTurnSpeed;

	if( PreventTurning )
        return;
	if( PlayerCamera != None )
	{
		PlayerCamera.ProcessViewRotation( DeltaTime, out_ViewRotation, DeltaRot );
	}
	
	if(ScriptBlockedInputs[EINBLOCK_Rotate])
	{
		DeltaRot.Yaw = 0;
		DeltaRot.Pitch = 0;
		DeltaRot.Roll = 0;	
	}
	else if ( AOCPawn(Pawn) != None )
	{	
		if ( AOCPawn(Pawn).StateVariables.bIsAttacking && LimitTurnSpeed  && Pawn.Weapon != none && AOCWeapon(Pawn.Weapon) != none)
		{
			MaxTurnSpeed = AOCWeapon(Pawn.Weapon).GetHorizontalRotateSpeed();
			MaxVertTurnSpeed = AOCWeapon(Pawn.Weapon).GetVerticalRotateSpeed();
			
			// BANGMOD: Loosen turn cap during parry animation - use Holy Water Sprinkler esque speeds
			if (AOCPawn(Pawn).StateVariables.bIsParrying)
			{
				MaxTurnSpeed = 75000.0;
				MaxVertTurnSpeed = 75000.0;
			}
			else
			{
				if ( AOCPawn(Pawn).StateVariables.bIsSprinting )
					MaxTurnSpeed = FMin(MaxTurnSpeed, MaxSprintTurnSpeed);
				
				if ( AOCPawn(Pawn).Weapon.IsInState('Reload') && AOCWeapon_Crossbow(AOCPawn(Pawn).Weapon) != none || AOCWeapon_PaviseShield(AOCPawn(Pawn).Weapon) != none)
				{
					MaxTurnSpeed = 0.0f;
					MaxVertTurnSpeed = 0.0f;
				}
			}
			
			if( AOCWeapon(Pawn.Weapon).IsInState( 'Windup' ) || AOCWeapon(Pawn.Weapon).IsInState( 'Release' ) || AOCWeapon(Pawn.Weapon).IsInState( 'Transition' ) || ( AOCPawn(Pawn).Weapon.IsInState('Reload') && AOCWeapon_Crossbow(AOCPawn(Pawn).Weapon) != none )
				|| (AOCPawn(Pawn).StateVariables.bIsAttacking && AOCPawn(Pawn).Weapon.CurrentFireMode == Attack_Sprint)
				|| AOCMeleeWeapon(Pawn.Weapon).bParryHitCounter)
			{
				if ( DeltaRot.Pitch >= 0 )
					DeltaRot.Pitch = FMin( DeltaRot.Pitch, MaxVertTurnSpeed * DeltaTime );
				else
					DeltaRot.Pitch = FMax( DeltaRot.Pitch, -MaxVertTurnSpeed * DeltaTime );
			}

			if ( DeltaRot.Yaw >= 0 )
				DeltaRot.Yaw = FMin( DeltaRot.Yaw, MaxTurnSpeed * DeltaTime);
			else
				DeltaRot.Yaw = FMax( DeltaRot.Yaw, -MaxTurnSpeed * DeltaTime);

			out_ViewRotation	+= DeltaRot;
			out_ViewRotation	 = LimitViewRotation(out_ViewRotation, -14000, 16383 );
		}
		else if(AOCWeapon_PaviseShield(AOCPawn(Pawn).Weapon) != none || AOCPawn(Pawn).PawnState == ESTATE_Execution)
		{
			if(AOCWeapon_PaviseShield(AOCPawn(Pawn).Weapon) != none)
			{
				out_ViewRotation.Pitch = 0;
			}
			
			DeltaRot.Yaw = 0;
			DeltaRot.Pitch = 0;
			DeltaRot.Roll = 0;
		}
		else
		{
			AOCPawn(Pawn).ProcessViewRotation( DeltaTime, out_ViewRotation, DeltaRot );
		}
		LastDeltaRot = DeltaRot;
	}
	else
	{
		out_ViewRotation += DeltaRot;
	}
}

// Override to prevent players from enabling ragdolls via console commands
exec function SetRagdollLimit(int NewLimit)
{
	// Always force to 0 regardless of what player requests
	MaxRagdolls = 0;
	default.MaxRagdolls = 0;
	
	// Clean up any existing ragdolls
	if (RagdolledPawns.Length > 0)
	{
		RemoveRagdolls(RagdolledPawns.Length);
	}
}

// Override to prevent ragdolls from being added in the first place
function AddRagdolledPawn(AOCPawn RagdolledPawn)
{
	// Immediately remove the ragdoll - don't add it to the list
	if (RagdolledPawn != none)
	{
		RagdolledPawn.LifeSpan = 0.1f;
	}
}

// Override Possess to enforce ragdoll limit and show optimization tip on first spawn
event Possess(Pawn inPawn, bool bVehicleTransition)
{
	super.Possess(inPawn, bVehicleTransition);
	
	// Force ragdolls disabled on every spawn (catches players with read-only configs)
	ConsoleCommand("SetRagdollLimit 0");
	
	// Show optimization tip once when player first spawns
	if (!bShownOptimizationTip && Role == ROLE_Authority)
	{
		bShownOptimizationTip = true;
		SetTimer(2.0f, false, 'ShowOptimizationTip');
	}
}

// Send optimization tip as a server message that appears in chat
function ShowOptimizationTip()
{
	ReceiveChatMessage("=== SlumpMod Performance Tip ===", EFAC_ALL, false, true, "#00FF00");
	ReceiveChatMessage("For best experience, edit UDKEngine.ini and set:", EFAC_ALL, false, true, "#FFAA00");  
	ReceiveChatMessage("  NetClientTicksPerSecond=120", EFAC_ALL, false, true, "#FFFFFF");
	ReceiveChatMessage("File: Documents\\My Games\\Chivalry Medieval Warfare\\UDKGame\\Config\\UDKEngine.ini", EFAC_ALL, false, true, "#FFAA00");
}

reliable server function bool IsAdmin() {
	return WorldInfo.Game.AccessControl.IsAdmin(self) || WorldInfo.NetMode == NM_Standalone;
}

reliable server function S_AdminBroadcastMessage(string Message, optional bool bShowName=true) {
	local AOCPlayerController PC;
	foreach WorldInfo.AllControllers(class'AOCPlayerController', PC) {
		if (bShowName)
			PC.ReceiveChatMessage(AOCPRI(PlayerReplicationInfo).GetHumanReadableName()$":"@Message, EFAC_ALL, false, false, ,false);
		else
			PC.ReceiveChatMessage(Message, EFAC_ALL, false, false, ,false);
	}
}

exec function AdminBroadcastMessage(String Message) {
	if (!PlayerReplicationInfo.bAdmin) {
		ClientDisplayConsoleMessage("You are not logged in as an administrator on this server.");
		return;
	}
	S_AdminBroadcastMessage(Message);
}

