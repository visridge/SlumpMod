function bool SetPause(bool bPause, optional delegate<CanUnpause> CanUnpauseDelegate=CanUnpause) {
	local bool bResult;
	if (bPause) {
		bFire = 0;
		// Pause gamepad rumbling too if needed
		bResult = WorldInfo.Game.SetPause(self,CanUnpauseDelegate);
		if (bResult) {
			PauseRumbleForAllPlayers();
			bIsPaused = true;
		}
	} else if (IsAdmin() && bIsPaused) {
		// Route through countdown instead of immediate unpause
		S_StartUnpauseCountdown();
	}
	return bResult;
}

// Explicit admin command to start unpause countdown
exec function UnPause() {
	if (!PlayerReplicationInfo.bAdmin) {
		ClientDisplayConsoleMessage("You are not logged in as an administrator on this server.");
		return;
	}
	S_StartUnpauseCountdown();
}

reliable server function S_StartUnpauseCountdown() {
	if (!IsAdmin())
		return;
	if (!bIsPaused) {
		ClientDisplayConsoleMessage("The game is not currently paused.");
		return;
	}
	UnpauseCountdownTime = Default.UnpauseCountdownTime;
	S_AdminBroadcastMessage("Unpausing in...", false);
	UnpauseCountdownTick();
	SetTimer(1.0f, true, 'UnpauseCountdownTick');
}

function UnpauseCountdownTick() {
	if (UnpauseCountdownTime == 0) {
		S_AdminBroadcastMessage("GO!", false);
		WorldInfo.Game.ClearPause();
		if (WorldInfo.Pauser == None) {
			WorldInfo.bGameplayFramePause = false;
			PauseRumbleForAllPlayers(false);
		}
		bIsPaused = false;
		ClearTimer('UnpauseCountdownTick');
	} else {
		S_AdminBroadcastMessage("    "$UnpauseCountdownTime$"...", false);
		UnpauseCountdownTime--;
	}
}


//quilt
//debug functions



simulated event tick(float DeltaTime)
{
	local rotator DeltaRot, ViewRotation, NewRotation;
	local GameEngine GEngine;
	super.tick(DeltaTime);
	
	// Continuously enforce FPS uncap when enabled
	if (bFPSUncapped && IsLocalPlayerController())
	{
		GEngine = GameEngine(class'Engine'.static.GetEngine());
		if (GEngine != None && GEngine.MaxSmoothedFrameRate < 200.0)
		{
			GEngine.MaxSmoothedFrameRate = 0.0;
		}
	}
	
	if (bShowGroundSpeed)
	{
		DrawDebugTextToHud(string(AOCPawn(Pawn).SprintTime) @string(AOCPawn(Pawn).StateVariables.bCanSprint), 40.0, 7.0);
		
		DrawDebugTextToHud(string(VSize(Pawn.Velocity * vect(1, 1, 0))), 40.0, 15.0);
		
		DrawDebugTextToHud("parry: " @string(AOCPawn(Pawn).StateVariables.bIsParrying), 40.0, 25.0);
	}
	
	if (Role == ROLE_SimulatedProxy)
	{
		// Calculate Delta to be applied on ViewRotation
		DeltaRot.Yaw	= 100;
		DeltaRot.Pitch	= 100;
		//DrawTextOverHead(string(DeltaRot));
		ProcessViewRotation( DeltaTime, ViewRotation, DeltaRot );
		SetRotation(ViewRotation);

		ViewShake( deltaTime );

		NewRotation = ViewRotation;
		NewRotation.Roll = Rotation.Roll;

		if ( Pawn != None )
			Pawn.FaceRotation(NewRotation, deltatime);
	}
	
}




