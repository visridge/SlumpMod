var float fLastParryTimeSeconds;                // The game time at which the pawn last parried
var float fSuccessiveParryStaminaReward;        // Flat stamina reward for parrying within successive parry threshold
var float fSuccessiveParryThresholdSeconds;     // The maximum time in seconds after the pawn's last parry that they are eligible for reward
// var int iLastParryCost;                      // [DEPRECATED] Stamina cost tracking no longer needed (flat reward system)

var bool bStoredExtraFlag;
var float altRiposteExtraWindup;

var float fLastReleaseStartTime;
var bool bShowHitTime;
var float fLastParrySuccessTime;                // Time when parry successfully activated (for riposte grace period)
var float fRiposteGracePeriod;                  // Grace period after parry where flinch is disabled (default 200ms)

