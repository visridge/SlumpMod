var BangModGFx_EscapeMain     EscapeMenu;

var BangModGFx_HUDManager HUD;


exec function ShowEscapeMenu(optional bool bPlaySound = true)
{
	// Initialize Escape menu here
	if (EscapeMenu == none || !EscapeMenu.bMovieIsOpen)
	{
		// Play Escape Menu Sound
		if (bPlaySound)
			AOCPlayerController(PlayerOwner).PlayEscapeMenuSound(true);

		EscapeMenu = none;
		EscapeMenu = BangModGFx_EscapeMain(OpenGFxScene(EscapeMenu, class'BangModGFx_EscapeMain', true, true, true, false));
		EscapeMenu.Start();
	}
}

function RemoveEscapeMenu()
{
	EscapeMenu.SetMovieCanReceiveFocus(false);
	EscapeMenu.Close(true);
	EscapeMenu = none;
	ShowCursor(false);
}


DefaultProperties
{
	PawnClass=class'BangModPawn'
	HUDClass=class'BangModGFx_HUDManager'
}