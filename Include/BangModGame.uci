    Families.Empty;
    Families(ECLASS_Archer)=class'BangModFamilyInfo_Agatha_Archer'
    Families(ECLASS_ManAtArms)=class'BangModFamilyInfo_Agatha_ManAtArms'
    Families(ECLASS_Vanguard)=class'BangModFamilyInfo_Agatha_Vanguard'
    Families(ECLASS_Knight)=class'BangModFamilyInfo_Agatha_Knight'
