    Families(8)=class'BangModFamilyInfo_Mason_Knight'
    Families(9)=class'BangModFamilyInfo_Mason_Archer'

    MinimumRespawnTime = 10.0f
    MaximumRespawnTime = 10.0f
    bDisableTeamDamagePenalty = true

}
